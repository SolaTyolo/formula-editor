{
  "name": "formula-editor-lark-demo",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "dev": "npm run build:lib && npm run dev -w formula-edit-lark-example",
    "dev:example": "npm run dev -w formula-edit-lark-example",
    "build": "npm run build -w formula-edit-lark && npm run build -w formula-edit-lark-example",
    "build:vercel": "npm run build -w formula-edit-lark-example",
    "build:lib": "npm run build -w formula-edit-lark",
    "preview": "npm run preview -w formula-edit-lark-example"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^5.4.11"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.61.1",
    "@rollup/rollup-linux-arm64-gnu": "4.61.1"
  }
}
