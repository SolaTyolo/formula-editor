{
  "name": "formula-edit-lark",
  "version": "1.0.0",
  "description": "React formula editor with Lark-style hint panel and field pills",
  "keywords": [
    "formula",
    "formula-edit",
    "formula-edit-react",
    "lark",
    "feishu",
    "tailwindcss"
  ],
  "license": "MIT",
  "author": "formula-edit-lark contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SolaTyolo/formula-editor.git"
  },
  "bugs": {
    "url": "https://github.com/SolaTyolo/formula-editor/issues"
  },
  "homepage": "https://github.com/SolaTyolo/formula-editor#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/formula-edit-lark.cjs",
  "module": "./dist/formula-edit-lark.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/formula-edit-lark.js",
      "require": "./dist/formula-edit-lark.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": false
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.6.2",
    "vite": "^5.4.11"
  }
}
